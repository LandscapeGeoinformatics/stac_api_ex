<!DOCTYPE html>
<html lang="en" data-theme="mytheme">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= assigns[:page_title] || "STAC API - Geokuup" %></title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"}/>
    <script phx-track-static defer src={~p"/assets/app.js"}>
    </script>
    
</head>
<body>
    <div class="min-h-screen">
        <div class="navbar bg-secondary shadow-md shadow-black/90 p-[0px] min-h-[56px] h-[56px]">
            <div class="flex-1 py-[0px] my-[0px]">
                <a href="/stac/web/" class="btn btn-ghost text-lg text-primary hover:bg-[#6a7282]">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="#d5df2e">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    STAC API
                </a>
            </div>
            <div class="flex-none">
                <ul class="menu menu-horizontal px-1 text-primary">
                    <li><a href="/stac/web/browse" class="btn btn-ghost hover:bg-[#6a7282]">Browse</a></li>
                    <li><a href="/stac/web/search" class="btn btn-ghost hover:bg-[#6a7282]">Search</a></li>
                    <li><a href="/stac/api/v1/docs" class="btn btn-ghost hover:bg-[#6a7282]">API Docs</a></li>
                </ul>
            </div>
        </div>

        <main>
            <%= @inner_content %>
        </main>

        <footer class="footer footer-center bg-secondary text-primary py-6 gap-3">
            <nav class="grid grid-flow-col gap-4">
                <a href="/stac/web/browse" class="link link-hover">Browse</a>
                <a href="/stac/web/search" class="link link-hover">Search</a>
                <a href="/stac/api/v1/" class="link link-hover">API</a>
                <a href="/stac/api/v1/docs" class="link link-hover">Documentation</a>
            </nav>
            <nav class="grid grid-flow-col gap-4">
                <a href="https://landscape-geoinformatics.ut.ee" target="_blank" rel="noopener" class="link link-hover">Landscape Geoinformatics Lab</a>
                <a href="https://geokuup.ee" target="_blank" rel="noopener" class="link link-hover">Geokuup Portal</a>
                <a href="https://stacspec.org/" target="_blank" rel="noopener" class="link link-hover">STAC Specification</a>
            </nav>
            <aside>
                <p>Geokuup STAC API | Landscape Geoinformatics Lab</p>
            </aside>
        </footer>
    </div>
</body>
</html>
