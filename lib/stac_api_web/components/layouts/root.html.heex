<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= assigns[:page_title] || "STAC API - Geokuup" %></title>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.14/dist/full.min.css" rel="stylesheet" type="text/css" />
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- MapLibre GL JS -->
    <link href="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css" rel="stylesheet" />
    <script src="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.js"></script>
    
    <!-- Turf JS for geometric calculations -->
    <script src="https://unpkg.com/@turf/turf@6/turf.min.js"></script>
    
    <!-- STAC Map Initialization Script -->
    <script>
      window.initStacMaps = function() {
        const mapElements = document.querySelectorAll('[data-map-id]');
        
        mapElements.forEach(element => {
          const mapId = element.getAttribute('data-map-id');
          const dataAttr = element.getAttribute('data-geojson');
          
          if (!mapId || !dataAttr) return;
          
          try {
            const geojsonData = JSON.parse(dataAttr);
            initMap(mapId, geojsonData);
          } catch (e) {
            console.error('Error parsing GeoJSON for map', mapId, e);
          }
        });
      };
      
      function initMap(mapId, geojsonData) {
        if (typeof maplibregl === 'undefined') {
          console.error('MapLibre GL not loaded');
          return;
        }
        
        // Convert extent data to GeoJSON if needed
        let geojson;
        if (geojsonData.type === 'Feature') {
          geojson = geojsonData;
        } else if (geojsonData.type === 'FeatureCollection') {
          geojson = geojsonData;
        } else if (Array.isArray(geojsonData) && geojsonData.length === 4) {
          const [minLon, minLat, maxLon, maxLat] = geojsonData;
          geojson = {
            type: 'Feature',
            geometry: {
              type: 'Polygon',
              coordinates: [[
                [minLon, minLat],
                [maxLon, minLat],
                [maxLon, maxLat],
                [minLon, maxLat],
                [minLon, minLat]
              ]]
            }
          };
        } else if (geojsonData.spatial && Array.isArray(geojsonData.spatial.bbox)) {
          const bbox = geojsonData.spatial.bbox[0];
          const [minLon, minLat, maxLon, maxLat] = bbox;
          geojson = {
            type: 'Feature',
            geometry: {
              type: 'Polygon',
              coordinates: [[
                [minLon, minLat],
                [maxLon, minLat],
                [maxLon, maxLat],
                [minLon, maxLat],
                [minLon, minLat]
              ]]
            }
          };
        }
        
        if (!geojson) return;
        
        // Initialize map
        const map = new maplibregl.Map({
          container: mapId,
          style: {
            version: 8,
            sources: {
              osm: {
                type: 'raster',
                tiles: ['https://tile.openstreetmap.org/{z}/{x}/{y}.png'],
                tileSize: 256,
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
              }
            },
            layers: [{ id: 'osm', type: 'raster', source: 'osm' }]
          },
          center: [25.7482, 58.3800],
          zoom: 7
        });
        
        map.on('load', function() {
          // Add source
          map.addSource(mapId + '-source', {
            type: 'geojson',
            data: geojson
          });
          
          // Add fill layer
          map.addLayer({
            id: mapId + '-fill',
            type: 'fill',
            source: mapId + '-source',
            paint: {
              'fill-color': '#088',
              'fill-opacity': 0.3
            }
          });
          
          // Add outline layer
          map.addLayer({
            id: mapId + '-outline',
            type: 'line',
            source: mapId + '-source',
            paint: {
              'line-color': '#088',
              'line-width': 2
            }
          });
          
          // Fit map to bounds
          try {
            const bounds = turf.bbox(geojson);
            map.fitBounds(bounds, { padding: 50 });
          } catch (e) {
            console.warn('Could not fit bounds', e);
          }
        });
      }
      
      // Auto-initialize maps when document is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', window.initStacMaps);
      } else {
        window.initStacMaps();
      }
    </script>
</head>
<body>
    <div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-green-50">
        <div class="navbar bg-base-100 shadow-lg">
            <div class="flex-1">
                <a href="/stac/web/" class="btn btn-ghost text-xl">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    STAC API
                </a>
            </div>
            <div class="flex-none">
                <ul class="menu menu-horizontal px-1">
                    <li><a href="/stac/web/browse" class="btn btn-ghost">Browse</a></li>
                    <li><a href="/stac/web/search" class="btn btn-ghost">Search</a></li>
                    <li><a href="/stac/api/v1/docs" class="btn btn-ghost">API Docs</a></li>
                </ul>
            </div>
        </div>

        <main>
            <%= @inner_content %>
        </main>

        <footer class="footer footer-center p-10 bg-base-200 text-base-content rounded mt-16">
            <nav class="grid grid-flow-col gap-4">
                <a href="/stac/web/browse" class="link link-hover">Browse</a>
                <a href="/stac/web/search" class="link link-hover">Search</a>
                <a href="/stac/api/v1/" class="link link-hover">API</a>
                <a href="/stac/api/v1/docs" class="link link-hover">Documentation</a>
            </nav>
            <nav>
                <div class="grid grid-flow-col gap-4">
                    <a href="https://landscape-geoinformatics.ut.ee" target="_blank" rel="noopener" class="link link-hover">Landscape Geoinformatics Lab</a>
                    <a href="https://geokuup.ee" target="_blank" rel="noopener" class="link link-hover">Geokuup Portal</a>
                    <a href="https://stacspec.org/" target="_blank" rel="noopener" class="link link-hover">STAC Specification</a>
                </div>
            </nav>
            <aside>
                <p>Geokuup STAC API | Landscape Geoinformatics Lab</p>
            </aside>
        </footer>
    </div>
</body>
</html>
