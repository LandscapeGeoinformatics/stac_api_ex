<div class="container mx-auto px-4 py-8">
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <h1 class="text-2xl font-bold text-gray-900">STAC Data Browser</h1>
      </div>
      
      <div class="flex space-x-2">
        <a href="/stac/web/search" 
           class="px-4 py-2 bg-purple-500 text-white rounded hover:bg-purple-600 transition-colors">
          🔍 Search Items
        </a>
      </div>
    </div>
  </div>

  <nav class="mb-6">
    <ol class="flex items-center space-x-2 text-sm">
      <%= for {breadcrumb, index} <- Enum.with_index(@breadcrumbs) do %>
        <%= if index > 0 do %>
          <li class="text-gray-400">/</li>
        <% end %>
        <li>
          <%= if index == length(@breadcrumbs) - 1 do %>
            <span class="text-gray-600 font-medium"><%= breadcrumb.name %></span>
          <% else %>
            <a href={"/stac/web/browse/#{breadcrumb.path}"} 
               class="text-blue-600 hover:text-blue-800 hover:underline">
              <%= breadcrumb.name %>
            </a>
          <% end %>
        </li>
      <% end %>
    </ol>
  </nav>

  <%= if @current_type == :catalog && @current_entity do %>
    <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
      <div class="flex items-start justify-between">
        <h2 class="text-lg font-semibold text-blue-900 mb-2"><%= @current_entity.title || @current_entity.id %></h2>

      </div>
      <%= if @current_entity.description do %>
        <p class="text-sm text-blue-700"><%= @current_entity.description %></p>
      <% end %>
    </div>
  <% end %>

  <%= if @current_type == :collection && @current_entity do %>
    <div class="mb-6 p-4 bg-green-50 rounded-lg border border-green-200">
      <div class="flex items-start justify-between">
        <h2 class="text-lg font-semibold text-green-900 mb-2"><%= @current_entity.title || @current_entity.id %></h2>
        <a href={"/stac/api/v1/collections/#{@current_entity.id}"}
           target="_blank" rel="noopener noreferrer"
           title="View API JSON"
           class="ml-4 flex-shrink-0 text-xs font-mono text-green-500 hover:text-green-700 border border-green-300 hover:border-green-500 rounded px-2 py-0.5 bg-white">
          { } JSON
        </a>
      </div>
      <%= if @current_entity.description do %>
        <p class="text-sm text-green-700 mb-2"><%= @current_entity.description %></p>
      <% end %>
      <%= if @current_entity.license do %>
        <p class="text-xs text-green-600 mb-3">License: <%= @current_entity.license %></p>
      <% end %>

      <%!-- Keywords --%>
      <%= if @current_entity.keywords not in [nil, []] do %>
        <div class="mb-2">
          <%= for word <- @current_entity.keywords do %>
            <span class="inline-block mr-1 mb-1 px-2 py-0.5 text-xs rounded-full bg-green-100 text-green-700 border border-green-200"><%= word %></span>
          <% end %>
        </div>
      <% end %>

      <%!-- Providers --%>
      <%= if @current_entity.providers not in [nil, []] do %>
        <div class="mb-2 text-xs text-green-700 space-y-0.5">
          <%= for p <- @current_entity.providers do %>
            <div class="flex flex-wrap items-baseline gap-1.5">
              <span class="font-medium"><%= p["name"] %></span>
              <%= if p["roles"] not in [nil, []] do %>
                <span class="text-green-500">(<%= Enum.join(p["roles"], ", ") %>)</span>
              <% end %>
              <%= if p["url"] do %>
                <a href={p["url"]} target="_blank" rel="noopener noreferrer"
                   class="text-green-400 hover:text-green-600 hover:underline break-all"><%= p["url"] %></a>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%!-- Summaries --%>
      <%= if @current_entity.summaries not in [nil, %{}] do %>
        <div class="mt-1 mb-1 text-xs text-green-600 space-y-0.5">
          <%= for {key, vals} <- @current_entity.summaries do %>
            <div class="flex items-baseline gap-1">
              <span class="font-medium text-green-500 shrink-0"><%= key %>:</span>
              <span><%= if is_list(vals), do: Enum.join(vals, ", "), else: inspect(vals) %></span>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="mt-3 flex space-x-4 text-xs text-green-400 border-t border-green-100 pt-2">
        <%= if @current_entity.inserted_at do %>
          <span>Created: <%= NaiveDateTime.to_string(@current_entity.inserted_at) %> UTC</span>
        <% end %>
        <%= if @current_entity.updated_at do %>
          <span>Updated: <%= NaiveDateTime.to_string(@current_entity.updated_at) %> UTC</span>
        <% end %>
      </div>

      <%!-- Map visualization for collection spatial extent --%>
      <%= if @current_type == :collection && @current_entity && @current_entity.extent do %>
        <div class="mt-4">
          <h3 class="text-lg font-semibold text-green-900 mb-3">Spatial Extent</h3>
          <.stac_map map_id="collection-extent-map" geojson_data={@current_entity.extent} />
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="bg-white shadow-sm border border-gray-200 rounded-lg overflow-hidden">
    <div class="bg-gray-50 px-6 py-3 border-b border-gray-200">
      <div class="grid grid-cols-12 gap-4 text-sm font-medium text-gray-700">
        <div class="col-span-6">Name</div>
        <div class="col-span-3">Type</div>
        <div class="col-span-3">Details</div>
      </div>
    </div>

    <div class="divide-y divide-gray-200">
      <%= for item <- @items do %>
        <div class="px-6 py-4 hover:bg-gray-50 transition-colors">
          <div class="grid grid-cols-12 gap-4 items-center">
            <div class="col-span-6 flex items-center space-x-3">
              <%= if item.is_directory do %>
                📁
              <% else %>
                <%= case item.type do %>
                  <% "Item" -> %>📄
                  <% _ -> %>📄
                <% end %>
              <% end %>
              
              <div class="flex flex-col">
                <%= if item.is_directory do %>
                  <a href={"/stac/web/browse/#{item.path}"} 
                     class="text-blue-600 hover:text-blue-800 hover:underline font-medium">
                    <%= item.title %>
                  </a>
                <% else %>
                  <a href={"/stac/web/browse/#{item.path}"} 
                     class="text-green-600 hover:text-green-800 hover:underline">
                    <%= item.title %>
                  </a>
                <% end %>
                <%= if item.description do %>
                  <span class="text-xs text-gray-500 mt-1"><%= String.slice(item.description, 0..80) %></span>
                <% end %>
              </div>
            </div>
            
            <div class="col-span-3">
              <span class={[
                "inline-flex px-2 py-1 text-xs font-medium rounded-full",
                type_badge_class(item.type)
              ]}>
                <%= item.type %>
              </span>
            </div>
            
            <div class="col-span-3 text-sm text-gray-500">
              <%= if Map.has_key?(item, :item_count) do %>
                <%= item.item_count %> items
              <% else %>
                <%= if Map.has_key?(item, :datetime) && item.datetime do %>
                  <%= Calendar.strftime(item.datetime, "%Y-%m-%d %H:%M") %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <%= if Enum.empty?(@items) do %>
        <div class="px-6 py-8 text-center text-gray-500">
          <%= case @current_type do %>
            <% :catalog -> %>
              <p>This catalog contains no collections or sub-catalogs</p>
            <% :collection -> %>
              <p>This collection contains no items</p>
            <% _ -> %>
              <p>No catalogs or collections found</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="mt-6 text-sm text-gray-500 text-center">
    <p>
      <%= length(@items) %> <%= if @current_type == :collection, do: "items", else: "entries" %>
      <%= if @collection_path do %>
        • Collection: <strong><%= @collection_path %></strong>
      <% end %>
    </p>
  </div>
</div>
