{
  "name": "stac_api_ex",
  "version": "1.0.0",
  "description": "This Phoenix application provides a STAC (SpatioTemporal Asset Catalog) API implementation with both REST API endpoints and HTML browser interface for exploring geospatial data catalogs.",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
"scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "deploy": "node node_modules/.bin/esbuild js/app.js --bundle --outdir=../priv/static/assets",
    "watch": "node node_modules/.bin/esbuild js/app.js --bundle --outdir=../priv/static/assets --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SudaisAkbar/stac_api_ex.git"
  },
