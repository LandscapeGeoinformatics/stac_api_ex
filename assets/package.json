  },
  "homepage": "https://github.com/SudaisAkbar/stac_api_ex#readme",
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "autoprefixer": "^10.5.0",
    "daisyui": "^4.12.24",
    "maplibre-gl": "^5.24.0",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19"
  }
}
