# STAC API Testing Suite
# Use with VS Code REST Client extension or similar tools
# 
# Base URL: http://localhost:4000
# 
# To use this file:
# 1. Install REST Client extension in VS Code
# 2. Make sure your Phoenix server is running (mix phx.server)
# 3. Click "Send Request" above each request

### ========================================
### ROOT ENDPOINT
### ========================================

# Get STAC root catalog
GET http://localhost:4000/stac/api/v1/
Accept: application/json

### ========================================
### COLLECTIONS ENDPOINTS
### ========================================

# Get all collections
GET http://localhost:4000/stac/api/v1/collections
Accept: application/json

# Get specific collection by ID
GET http://localhost:4000/stac/api/v1/collections/world_clim-wc2_1_30s_tmin
Accept: application/json

# Get items in a specific collection
GET http://localhost:4000/stac/api/v1/collections/world_clim-wc2_1_30s_tmin/items
Accept: application/geo+json

# Get items in another collection
GET http://localhost:4000/stac/api/v1/collections/est-topo-mtr-dem_5m_pzone/items
Accept: application/geo+json

### ========================================
### SEARCH ENDPOINT - BASIC QUERIES
### ========================================

# Basic search (default limit 10)
GET http://localhost:4000/stac/api/v1/search
Accept: application/geo+json

# Search with custom limit
GET http://localhost:4000/stac/api/v1/search?limit=5
Accept: application/geo+json

# Search with pagination
GET http://localhost:4000/stac/api/v1/search?limit=5&offset=10
Accept: application/geo+json

### ========================================
### SEARCH ENDPOINT - SPATIAL QUERIES
### ========================================

# Search by bounding box (Estonia area)
GET http://localhost:4000/stac/api/v1/search?bbox=21,57,28,60
Accept: application/geo+json

# Search by bounding box (global area)
GET http://localhost:4000/stac/api/v1/search?bbox=0,0,10,10
Accept: application/geo+json

# Search by bounding box (Europe area)
GET http://localhost:4000/stac/api/v1/search?bbox=-10,35,40,70
Accept: application/geo+json

# Search by bounding box (small area)
GET http://localhost:4000/stac/api/v1/search?bbox=24,58,26,60
Accept: application/geo+json

### ========================================
### SEARCH ENDPOINT - TEMPORAL QUERIES
### ========================================

# Search by datetime range (2024)
GET http://localhost:4000/stac/api/v1/search?datetime=2024-01-01T00:00:00Z/2024-12-31T23:59:59Z
Accept: application/geo+json

# Search by datetime range (2025)
GET http://localhost:4000/stac/api/v1/search?datetime=2025-01-01T00:00:00Z/2025-12-31T23:59:59Z
Accept: application/geo+json

# Search by specific date
GET http://localhost:4000/stac/api/v1/search?datetime=2024-02-13T12:00:00Z
Accept: application/geo+json

### ========================================
### SEARCH ENDPOINT - COLLECTION FILTERS
### ========================================

# Search by single collection
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin
Accept: application/geo+json

# Search by another collection
GET http://localhost:4000/stac/api/v1/search?collections=est-topo-mtr-dem_5m_pzone
Accept: application/geo+json

# Search by multiple collections
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin,est-topo-mtr-dem_5m_pzone
Accept: application/geo+json

# Search by collection with limit
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin&limit=20
Accept: application/geo+json

### ========================================
### SEARCH ENDPOINT - COMBINED QUERIES
### ========================================

# Collection + Bounding Box
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin&bbox=0,0,180,90
Accept: application/geo+json

# Collection + Bounding Box + Limit
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin&bbox=0,0,180,90&limit=5
Accept: application/geo+json

# Collection + Datetime + Limit
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin&datetime=2024-01-01T00:00:00Z/2024-12-31T23:59:59Z&limit=10
Accept: application/geo+json

# Bounding Box + Datetime
GET http://localhost:4000/stac/api/v1/search?bbox=21,57,28,60&datetime=2024-01-01T00:00:00Z/2024-12-31T23:59:59Z
Accept: application/geo+json

# Full combination
GET http://localhost:4000/stac/api/v1/search?collections=world_clim-wc2_1_30s_tmin&bbox=0,0,180,90&datetime=2024-01-01T00:00:00Z/2024-12-31T23:59:59Z&limit=10
Accept: application/geo+json

### ========================================
### SEARCH ENDPOINT - SPATIAL INTERSECTS
### ========================================

# Search by intersects with Polygon (Estonia)
GET http://localhost:4000/stac/api/v1/search?intersects={"type":"Polygon","coordinates":[[[21,57],[21,60],[28,60],[28,57],[21,57]]]}&limit=5
Accept: application/geo+json

# Search by intersects with Point (Tallinn)
GET http://localhost:4000/stac/api/v1/search?intersects={"type":"Point","coordinates":[24.7536,59.4370]}&limit=5
Accept: application/geo+json

# Search by intersects with larger area
GET http://localhost:4000/stac/api/v1/search?intersects={"type":"Polygon","coordinates":[[[0,0],[0,90],[180,90],[180,0],[0,0]]]}&limit=10
Accept: application/geo+json

